a = 40
b = 70
c = 50
d = 60

TOTAL = a + b + c + d
# Calculate percentage: (Obtained / Total possible) * 100
# Since there are 4 subjects out of 100, the total possible is 400
percentage = (TOTAL / 400) * 100

# Convert the number to a string before adding the "%" sign
Percentage = str(percentage) + "%"
print(f"{percentage}%")